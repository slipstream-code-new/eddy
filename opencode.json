{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/*.md"
  ],
  "default_agent": "build",
  "plugin": [
    "opencode-rtk",
    [
      "opencode-rgr-loop@0.2.3",
      {
        "classification": {
          "test": {
            "paths": [
              "examples/**",
              "tests/**",
              "**/*_test.rs",
              "**/*_tests.rs"
            ]
          },
          "production": {
            "paths": [
              "src/**"
            ],
            "exclude": [
              "**/*_test.rs",
              "**/*_tests.rs"
            ]
          },
          "nonBehavioral": {
            "paths": [
              "README.md",
              "docs/**",
              ".opencode/**",
              "*.toml",
              "*.lock",
              "*.nix",
              "build.rs",
              "scripts/**",
              "justfile",
              "lefthook.yml",
              "AGENTS.md",
              "opencode.json"
            ]
          },
          "protected": {
            "paths": [
              ".env",
              ".env.*",
              "**/*secret*",
              "**/*credential*",
              "**/*.key",
              "**/*.pem"
            ]
          },
          "allowUnknown": false
        }
      }
    ]
  ],
  "lsp": {
    "rust": {
      "command": [
        "nix",
        "develop",
        ".",
        "--command",
        "rust-analyzer"
      ],
      "extensions": [
        ".rs"
      ],
      "initialization": {
        "cargo": {
          "allFeatures": true
        },
        "check": {
          "command": "clippy"
        }
      }
    }
  },
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "rgr_initialize": "deny",
    "todowrite": "allow",
    "lsp": "allow",
    "bash": "allow",
    "edit": {
      ".env": "deny",
      ".env.*": "deny",
      "**/*secret*": "ask",
      "**/*credential*": "ask",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "*": "allow"
    },
    "external_directory": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "snapshot": true,
  "share": "manual"
}
